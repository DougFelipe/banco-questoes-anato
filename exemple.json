    {
      "id": "osso-001",
      "pergunta": "Qual osso protege principalmente o cerebro?",
      "alternativas": [
        {
          "letra": "A",
          "texto": "Cranio",
          "correta": true,
          "explicacao": "O cranio forma a caixa craniana, que envolve e protege o encefalo."
        },
        {
          "letra": "B",
          "texto": "Esterno",
          "correta": false,
          "explicacao": "O esterno protege estruturas toracicas, nao o cerebro."
        },
        {
          "letra": "C",
          "texto": "Femur",
          "correta": false,
          "explicacao": "O femur e um osso do membro inferior."
        },
        {
          "letra": "D",
          "texto": "Patela",
          "correta": false,
          "explicacao": "A patela fica no joelho e nao participa da protecao do cerebro."
        },
        {
          "letra": "E",
          "texto": "Tibia",
          "correta": false,
          "explicacao": "A tibia e um osso da perna."
        }
      ],
      "resposta_correta": "A",
      "tema": "Sistema Esqueletico",
      "subtema": "Ossos do Cranio",
      "tags": ["anatomia", "ossos", "cranio"]
    },
